{
  "name": "@marcher-lam/stdd-copilot",
  "version": "1.0.0",
  "description": "STDD (Specification + Test Driven Development) Copilot CLI",
  "main": "cli.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node cli.js",
    "test": "jest",
    "test:all": "jest --runInBand",
    "test:docs": "jest --runInBand __tests__/docs-taxonomy-consistency.test.js __tests__/docs-cli-examples-consistency.test.js",
    "test:coverage": "jest --coverage --runInBand",
    "test:benchmark": "node test-support/benchmark.js",
    "premerge": "npm run audit && npm run test:docs && jest --runInBand --testPathIgnorePatterns=__tests__/docs-taxonomy-consistency.test.js --testPathIgnorePatterns=__tests__/docs-cli-examples-consistency.test.js",
    "audit": "npm audit --audit-level=high",
    "lint": "echo 'Lint not configured yet'",
    "build": "echo 'No build step required'",
    "clean": "rm -rf node_modules coverage benchmark-results.json stdd/logs",
    "prepublishOnly": "npm run premerge"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Marcher-lam/STDD-COPILOT.git"
  },
  "bin": {
    "stdd": "cli.js"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "inquirer": "^8.2.5",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "files": [
    "cli.js",
    "src",
    "schemas",
    ".claude",
    "stdd"
  ]
}
